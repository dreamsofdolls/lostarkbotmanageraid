DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
GUILD_ID=your_test_server_id_here
MONGO_URI=your_mongodb_connection_string_here
MONGO_DB_NAME=manage
DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional. Default: true.
# Ensures schema indexes at bot startup. Set to "false" only if your Mongo
# user cannot create indexes or you manage indexes manually in Atlas.
MONGO_ENSURE_INDEXES=true

# Optional. Default: true.
# Controls the /raid-channel text monitor feature.
#   true  - bot requests the privileged MessageContent intent and listens
#           on MessageCreate to parse raid-clear messages. REQUIRES the
#           Message Content Intent to be enabled in Discord Developer
#           Portal → Bot → Privileged Gateway Intents, otherwise Discord
#           rejects the login and the bot exits.
#   false - skip the privileged intent and the listener; slash commands
#           (including /raid-channel config) still work. Use this when
#           the portal toggle is off or the feature is not wanted yet.
TEXT_MONITOR_ENABLED=true

# Optional. Default: empty.
# Comma-separated Discord user IDs who are allowed to invoke /raid-check
# and are treated as Raid Managers across the bot. Empty/missing means
# /raid-check rejects every invocation and the bot warns at boot. Add
# the user IDs (not usernames) of your raid leaders here; operator
# rotation = update env + redeploy.
#
# Manager privileges (applies to every listed ID):
#   - /raid-auto-manage / /raid-status piggyback / /raid-check Sync share
#     a shorter 30-second sync cooldown instead of the 15-minute default.
#   - Each manager roster swaps the 📁 folder header icon for a 👑 in
#     /raid-check and /raid-status embeds (one crown per roster, not per
#     character, so the cue stays visible without cluttering the card).
# A single tier (no separate Owner) keeps the UX flat for small deployments.
#
#   Example: RAID_MANAGER_ID=123456789012345678,987654321098765432
RAID_MANAGER_ID=

# Optional. Default: false.
# Killswitch for the Phase 3 24h passive auto-sync scheduler. Set to
# "true" to skip every tick without redeploy - useful if lostark.bible
# starts returning Cloudflare 403 under load and ops need to back off
# immediately. Phase 1 manual /raid-auto-manage action:sync and Phase 2
# /raid-status piggyback remain unaffected.
AUTO_MANAGE_DAILY_DISABLED=false

# REQUIRED to enable the local-sync web companion. No default.
# HMAC-SHA256 secret used to sign short-lived (15-min) JWT-style tokens
# that bridge Discord identity into the /sync companion page. Tokens
# are minted by /raid-auto-manage action:local-on (DM embed) and by
# the stuck-nudge button in /raid-status.
#
# bot/services/local-sync/tokens.js throws and refuses to mint if this
# is missing or shorter than 16 chars, so the local-sync feature stays
# off until you provision a strong secret. This is intentional: a
# silent dev-default would let production ship insecure tokens.
#
# Rotation: bump this value to invalidate every in-flight token at
# once. Users re-run /raid-auto-manage action:local-on to get a fresh
# link. No client-side refresh path exists by design.
#
# Generate with e.g. `openssl rand -hex 32`.
LOCAL_SYNC_TOKEN_SECRET=

# REQUIRED to render clickable local-sync links. No default.
# Public origin of your bot deployment, with no trailing slash. The
# bot composes companion URLs as `${PUBLIC_BASE_URL}/sync?token=...`
# in three places: the /raid-auto-manage local-on success embed, the
# stuck-nudge button in /raid-status, and the auto-manage handler.
# If empty, tokens still mint and the bot still works, but the embeds
# omit the link entirely - users would have to type the URL by hand.
#
#   Example: PUBLIC_BASE_URL=https://your-bot.up.railway.app
PUBLIC_BASE_URL=

# Optional. Default: 3000. Railway provides this automatically in prod.
# Listen port for the local-sync HTTP server (bot/services/local-sync/
# http-server.js). The server binds 0.0.0.0 so the platform's load
# balancer can reach it; do not change that bind or the deploy will
# read as "unhealthy" because no public traffic can land. Only set
# this locally if 3000 collides with another dev service.
PORT=

# Optional. Default: false.
# Killswitch for the local-sync web companion HTTP server. Set "true"
# to skip startLocalSyncHttpServer entirely - the Discord bot still
# runs, all slash commands keep working, but /raid-auto-manage
# action:local-on and the /sync companion page become unreachable.
# Mostly useful for emergency troubleshooting (e.g. the HTTP server
# crash-loops and you want a clean Discord-only deploy while you
# investigate). Read in bot/app/local-sync-web.js.
LOCAL_SYNC_HTTP_DISABLED=false

# /raid-bg storage uses no env var and no rehost channel. Uploaded
# background bytes are downscaled + JPEG-compressed on the way in (≤ 2 MB
# per stored image) and persisted as BSON Binary in the `userbackgrounds`
# Mongo collection (`bot/models/userBackground.js`, separate from the User
# collection so the hot-path doc stays small). Users can store 1-4 images,
# capped by their visible roster count, and shared roster pages use the viewer's
# own pool. Users run /raid-bg set / view / remove directly with no admin setup.

# DO NOT SET THIS. NODE_TLS_REJECT_UNAUTHORIZED=0 disables certificate
# validation for every outbound HTTPS call (Discord, MongoDB, lostark.bible)
# and is a MITM hazard. The bot's startup guard refuses to launch if it
# detects this variable. Listed here so operators don't add it back without
# realizing it's deliberately blocked.
# NODE_TLS_REJECT_UNAUTHORIZED=
