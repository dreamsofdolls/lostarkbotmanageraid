DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here
GUILD_ID=your_test_server_id_here
MONGO_URI=your_mongodb_connection_string_here
MONGO_DB_NAME=manage
DNS_SERVERS=8.8.8.8,1.1.1.1

# Optional. Default: true.
# Controls the /raid-channel text monitor feature.
#   true  — bot requests the privileged MessageContent intent and listens
#           on MessageCreate to parse raid-clear messages. REQUIRES the
#           Message Content Intent to be enabled in Discord Developer
#           Portal → Bot → Privileged Gateway Intents, otherwise Discord
#           rejects the login and the bot exits.
#   false — skip the privileged intent and the listener; slash commands
#           (including /raid-channel config) still work. Use this when
#           the portal toggle is off or the feature is not wanted yet.
TEXT_MONITOR_ENABLED=true